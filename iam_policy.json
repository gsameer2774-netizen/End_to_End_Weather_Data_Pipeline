{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:ListBucket"
			],
			"Resource": [
				"arn:aws:s3:::idris-weather-data-pipeline",
				"arn:aws:s3:::idris-weather-data-pipeline/*"
			]
		},
		{
			"Effect": "Allow",
			"Action": [
				"glue:*",
				"logs:CreateLogGroup",
				"logs:CreateLogStream",
				"logs:PutLogEvents"
			],
			"Resource": [
				"*"
			]
		}
	]
}